# Maintainer: ripsync contributors <ionescudan888@gmail.com>
pkgname=ripsync-bin
_pkgname=ripsync
pkgver=0.4.0
pkgrel=1
pkgdesc="A fast, memory-safe local directory sync tool (prebuilt binary)"
arch=('x86_64' 'aarch64')
url="https://github.com/beeboyd/ripsync"
license=('MIT' 'Apache-2.0')
provides=('ripsync')
conflicts=('ripsync')
_base="https://github.com/beeboyd/ripsync/releases/download/v$pkgver"
source_x86_64=("$_base/ripsync-v$pkgver-x86_64-unknown-linux-gnu.tar.gz")
source_aarch64=("$_base/ripsync-v$pkgver-aarch64-unknown-linux-gnu.tar.gz")
# Replace with the real digests at publish time: `updpkgsums`.
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')

package() {
    # cargo-dist tarballs extract to a single ripsync-v<ver>-<target>/ directory
    # containing the binary and an assets/ subdirectory.
    local dir
    dir="$(find . -maxdepth 1 -type d -name 'ripsync-v*' | head -n1)"
    cd "$dir"

    install -Dm755 ripsync "$pkgdir/usr/bin/ripsync"
    install -Dm644 assets/ripsync.1 "$pkgdir/usr/share/man/man1/ripsync.1"
    install -Dm644 assets/ripsync.bash "$pkgdir/usr/share/bash-completion/completions/ripsync"
    install -Dm644 assets/ripsync.fish "$pkgdir/usr/share/fish/vendor_completions.d/ripsync.fish"
    install -Dm644 assets/_ripsync "$pkgdir/usr/share/zsh/site-functions/_ripsync"
    install -Dm644 LICENSE-MIT "$pkgdir/usr/share/licenses/$_pkgname/LICENSE-MIT"
    install -Dm644 LICENSE-APACHE "$pkgdir/usr/share/licenses/$_pkgname/LICENSE-APACHE"
}
